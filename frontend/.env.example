# NextAuth (required on Vercel)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# Backend API (build-time rewrites + server-side login)
BACKEND_URL=http://127.0.0.1:8000

# Optional override for NextAuth credentials login (defaults to BACKEND_URL/api/auth/login)
# NEXTAUTH_BACKEND_URL=http://127.0.0.1:8000/api/auth/login
